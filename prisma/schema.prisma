generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  address        String          @id @unique
  createdAt      DateTime        @default(now())
  profile        Profile         @relation(fields: [profileId], references: [id])
  profileId      String          @unique
  nodes          Node[]
  watchlistStats WatchlistStat[]
}

model WatchlistStat {
  id                 Int      @id @default(autoincrement())
  createdAt          DateTime @default(now())
  User               User?    @relation(fields: [userAddress], references: [address])
  userAddress        String?
  totalNodes         Int
  totalDataStaked    Float
  totalRewardsInData Float
  totalClaimCount    Int
}

model CronRun {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  runTimeInSeconds Float
  finalStatus      Int
  errorMessage     String?
}

model AppStat {
  id                 Int      @id @default(autoincrement())
  createdAt          DateTime @default(now())
  totalUsers         Int
  totalNodesWatched  Int
  totalDataStaked    Float
  totalRewardsInData Float
  totalClaimCount    Int
}

model Profile {
  id        String   @id @default(uuid())
  gradient  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User?
}

model Node {
  id          String   @id @default(uuid())
  address     String
  createdAt   DateTime @default(now())
  name        String   @default("Default node name")
  updatedAt   DateTime @default(now()) @updatedAt
  User        User?    @relation(fields: [userAddress], references: [address])
  userAddress String?
}

model BrubeckStats {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  dailyAPR        Float
  dailyAPY        Float
  spotAPR         Float
  spotAPY         Float
  dailyDataStaked Float
  spotDataStaked  Float
}
